VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Required for npm run supabase:apply-policies -- --from .env.production.local --apply
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres
EVENT_ADMIN_USERNAME=admin-professor
EVENT_ADMIN_PASSWORD=replace-with-strong-event-password

# Required for npm run vercel:set-production-env -- --from .env.production.local --require-admin-verifier --apply
# and for npm run verify:supabase:mutations
VERIFY_SUPABASE_ADMIN_USERNAME=admin-professor
VERIFY_SUPABASE_ADMIN_PASSWORD=replace-with-strong-event-password
